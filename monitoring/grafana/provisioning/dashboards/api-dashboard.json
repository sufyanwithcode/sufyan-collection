{
  "title": "Sufyan Collection — API Dashboard",
  "uid":   "sc-api-dashboard",
  "tags":  ["sufyan-collection", "api", "nodejs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total HTTP Requests",
      "gridPos": {"h":4,"w":6,"x":0,"y":0},
      "targets": [{ "expr": "sum(http_requests_total)", "legendFormat": "Total Requests", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null}] } } }
    },
    {
      "id": 2, "type": "stat", "title": "API Uptime (seconds)",
      "gridPos": {"h":4,"w":6,"x":6,"y":0},
      "targets": [{ "expr": "process_uptime_seconds", "legendFormat": "Uptime", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null}] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Memory Usage (MB)",
      "gridPos": {"h":4,"w":6,"x":12,"y":0},
      "targets": [{ "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS Memory", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "MB", "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":200},{"color":"red","value":400}] } } }
    },
    {
      "id": 4, "type": "stat", "title": "CPU Usage (seconds)",
      "gridPos": {"h":4,"w":6,"x":18,"y":0},
      "targets": [{ "expr": "rate(process_cpu_seconds_total[5m]) * 100", "legendFormat": "CPU %", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":70},{"color":"red","value":90}] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Requests per Minute",
      "gridPos": {"h":8,"w":12,"x":0,"y":4},
      "targets": [{ "expr": "rate(http_requests_total[1m]) * 60", "legendFormat": "{{method}} {{route}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 6, "type": "timeseries", "title": "HTTP Request Duration (p95)",
      "gridPos": {"h":8,"w":12,"x":12,"y":4},
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 latency", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP Status Code Breakdown",
      "gridPos": {"h":8,"w":24,"x":0,"y":12},
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total[5m]))", "legendFormat": "Status {{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    }
  ]
}
