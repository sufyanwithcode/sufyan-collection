// ─────────────────────────────────────────────────────────────
//  Sufyan Collection by Capra — Jenkins CI/CD Pipeline
//  Declarative Pipeline
// ─────────────────────────────────────────────────────────────

pipeline {

    // Run on any available agent (or specify a label)
    agent any

    // ── Environment Variables ──────────────────────────────────
    environment {
        APP_NAME        = 'sufyan-collection'
        DOCKER_HUB_USER = 'sufyanwithcode'
        BACKEND_IMAGE   = "${DOCKER_HUB_USER}/sc-backend"
        FRONTEND_IMAGE  = "${DOCKER_HUB_USER}/sc-frontend"
        K8S_NAMESPACE   = 'sufyan-collection'
        GIT_REPO        = 'https://github.com/sufyanwithcode/sufyan-collection.git'
        GIT_BRANCH      = 'main'

        // Credentials stored in Jenkins Credentials Manager
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
        KUBECONFIG_CREDENTIALS_ID = 'kubeconfig-credentials'
    }

    // ── Build Triggers ─────────────────────────────────────────
    triggers {
        // Poll SCM every 5 minutes  OR  use GitHub webhook
        // pollSCM('H/5 * * * *')
        githubPush()
    }

    // ── Pipeline Options ───────────────────────────────────────
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        timestamps()
    }

    // ── Stages ─────────────────────────────────────────────────
    stages {

        // ── 1. Checkout ──────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "━━━ Stage 1: Checkout ━━━"
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${GIT_BRANCH}"]],
                    userRemoteConfigs: [[url: "${GIT_REPO}"]]
                ])
                echo "✅  Code checked out from ${GIT_REPO} (branch: ${GIT_BRANCH})"
                sh 'git log --oneline -5'
            }
        }

        // ── 2. Set Build Tag ─────────────────────────────────
        stage('Set Build Tag') {
            steps {
                echo "━━━ Stage 2: Set Build Tag ━━━"
                script {
                    env.BUILD_TAG = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()
                    env.IMAGE_TAG = "${env.BUILD_TAG}-${env.BUILD_NUMBER}"
                    echo "🏷️   Image tag: ${env.IMAGE_TAG}"
                }
            }
        }

        // ── 3. Install Dependencies ──────────────────────────
        stage('Install Dependencies') {
            parallel {
                stage('Backend — npm install') {
                    steps {
                        echo "━━━ Stage 3a: Backend npm install ━━━"
                        dir('backend') {
                            sh 'npm ci --only=production'
                            echo "✅  Backend dependencies installed"
                        }
                    }
                }
                stage('Frontend — npm install') {
                    steps {
                        echo "━━━ Stage 3b: Frontend npm install ━━━"
                        dir('frontend') {
                            sh 'npm ci'
                            echo "✅  Frontend dependencies installed"
                        }
                    }
                }
            }
        }

        // ── 4. Run Tests ─────────────────────────────────────
        stage('Run Tests') {
            parallel {
                stage('Backend Tests') {
                    steps {
                        echo "━━━ Stage 4a: Backend Tests ━━━"
                        dir('backend') {
                            sh '''
                                npm test -- --passWithNoTests --forceExit 2>&1 || true
                            '''
                            echo "✅  Backend tests completed"
                        }
                    }
                }
                stage('Frontend Build Test') {
                    steps {
                        echo "━━━ Stage 4b: Frontend Build Test ━━━"
                        dir('frontend') {
                            sh '''
                                CI=false npm run build
                                echo "✅  Frontend build successful"
                                rm -rf build
                            '''
                        }
                    }
                }
            }
        }

        // ── 5. Security Scan (optional) ──────────────────────
        stage('Security Scan') {
            steps {
                echo "━━━ Stage 5: Security Scan ━━━"
                dir('backend') {
                    sh '''
                        npm audit --audit-level=high 2>&1 || echo "⚠️  npm audit warnings found (non-blocking)"
                    '''
                }
                echo "✅  Security scan completed"
            }
        }

        // ── 6. Build Docker Images ───────────────────────────
        stage('Build Docker Images') {
            steps {
                echo "━━━ Stage 6: Build Docker Images ━━━"
                script {
                    // Build backend image
                    echo "🔨  Building backend image: ${BACKEND_IMAGE}:${IMAGE_TAG}"
                    sh """
                        docker build \\
                            -t ${BACKEND_IMAGE}:${IMAGE_TAG} \\
                            -t ${BACKEND_IMAGE}:latest \\
                            ./backend
                    """

                    // Build frontend image
                    echo "🔨  Building frontend image: ${FRONTEND_IMAGE}:${IMAGE_TAG}"
                    sh """
                        docker build \\
                            --build-arg REACT_APP_API_URL=/api \\
                            -t ${FRONTEND_IMAGE}:${IMAGE_TAG} \\
                            -t ${FRONTEND_IMAGE}:latest \\
                            ./frontend
                    """

                    echo "✅  Docker images built successfully"
                    sh "docker images | grep ${DOCKER_HUB_USER}"
                }
            }
        }

        // ── 7. Push Docker Images ────────────────────────────
        stage('Push to Docker Hub') {
            steps {
                echo "━━━ Stage 7: Push to Docker Hub ━━━"
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDENTIALS_ID}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin

                        docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                        docker push ${BACKEND_IMAGE}:latest
                        echo "✅  Backend image pushed"

                        docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
                        docker push ${FRONTEND_IMAGE}:latest
                        echo "✅  Frontend image pushed"

                        docker logout
                    """
                }
            }
        }

        // ── 8. Deploy to Kubernetes ──────────────────────────
        stage('Deploy to Kubernetes') {
            steps {
                echo "━━━ Stage 8: Deploy to Kubernetes ━━━"
                withCredentials([file(
                    credentialsId: "${KUBECONFIG_CREDENTIALS_ID}",
                    variable:      'KUBECONFIG'
                )]) {
                    sh """
                        # Apply all manifests
                        kubectl apply -f k8s/00-namespace.yaml
                        kubectl apply -f k8s/01-secrets-configmap.yaml
                        kubectl apply -f k8s/02-mongo.yaml
                        kubectl apply -f k8s/03-backend.yaml
                        kubectl apply -f k8s/04-frontend.yaml
                        kubectl apply -f k8s/05-ingress.yaml
                        kubectl apply -f k8s/06-prometheus.yaml
                        kubectl apply -f k8s/07-grafana.yaml

                        # Update images to the new tagged version
                        kubectl set image deployment/sc-backend  \\
                            backend=${BACKEND_IMAGE}:${IMAGE_TAG}  \\
                            -n ${K8S_NAMESPACE}

                        kubectl set image deployment/sc-frontend \\
                            frontend=${FRONTEND_IMAGE}:${IMAGE_TAG} \\
                            -n ${K8S_NAMESPACE}

                        echo "⏳  Waiting for rollout..."
                        kubectl rollout status deployment/sc-backend  -n ${K8S_NAMESPACE} --timeout=120s
                        kubectl rollout status deployment/sc-frontend -n ${K8S_NAMESPACE} --timeout=120s
                        echo "✅  Deployments updated successfully"
                    """
                }
            }
        }

        // ── 9. Smoke Test ────────────────────────────────────
        stage('Smoke Test') {
            steps {
                echo "━━━ Stage 9: Smoke Test ━━━"
                sh """
                    sleep 15
                    # Health check the API via Docker (if running locally)
                    STATUS=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:5000/health 2>/dev/null || echo "000")
                    if [ "\$STATUS" = "200" ]; then
                        echo "✅  API health check passed (HTTP \$STATUS)"
                    else
                        echo "⚠️  API health check returned HTTP \$STATUS (may be expected in pure K8s deployment)"
                    fi
                """
            }
        }

        // ── 10. Clean Up Docker Images ───────────────────────
        stage('Cleanup') {
            steps {
                echo "━━━ Stage 10: Cleanup ━━━"
                sh """
                    docker rmi ${BACKEND_IMAGE}:${IMAGE_TAG}  2>/dev/null || true
                    docker rmi ${FRONTEND_IMAGE}:${IMAGE_TAG} 2>/dev/null || true
                    docker system prune -f --filter "until=24h" 2>/dev/null || true
                    echo "✅  Docker cleanup complete"
                """
            }
        }
    }

    // ── Post Actions ───────────────────────────────────────────
    post {
        always {
            echo "━━━ Pipeline Finished — Build #${BUILD_NUMBER} ━━━"
        }
        success {
            echo """
            ╔══════════════════════════════════════════╗
            ║   ✅  DEPLOYMENT SUCCESSFUL               ║
            ║   App:    Sufyan Collection by Capra      ║
            ║   Build:  #${BUILD_NUMBER}                ║
            ║   Tag:    ${env.IMAGE_TAG ?: 'N/A'}       ║
            ╚══════════════════════════════════════════╝
            """
        }
        failure {
            echo """
            ╔══════════════════════════════════════════╗
            ║   ❌  DEPLOYMENT FAILED                   ║
            ║   Build: #${BUILD_NUMBER}                 ║
            ║   Check console output for details        ║
            ╚══════════════════════════════════════════╝
            """
        }
        unstable {
            echo "⚠️  Pipeline completed with warnings — Build #${BUILD_NUMBER}"
        }
    }
}
